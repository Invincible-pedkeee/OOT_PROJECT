<Window x:Class="Muzej.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Muzej"
        mc:Ignorable="d"
        AllowDrop="True"
        DragOver="Window_DragOver"
        Title="MainWindow" Height="600" Width="980" MinHeight="600" MinWidth="900">
    <Window.Resources>
        <!--  Boje  Resursi -->
        <SolidColorBrush x:Key="BackGroundColor" Color="CornflowerBlue" />
        <SolidColorBrush x:Key="Color1" Color="LightSlateGray" />
        <SolidColorBrush x:Key="Color2" Color="Black" />
        <SolidColorBrush x:Key="Color3" Color="LightGray" />

        <!--  Tabs Style Resurs  -->
        <Style  x:Name="TabsStyle" TargetType="TabItem">
            <Setter Property="FontWeight" Value="Normal"></Setter>
            <Setter Property="Foreground" Value="Chocolate"></Setter>  
            <Setter Property="Background" Value="{StaticResource Color3}"></Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="FontWeight" Value="Bold"></Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Name="DataGridHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FFF5F6F8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>

        
        
        
        

    </Window.Resources>
    <Grid Background="{StaticResource Color3}" Margin="0"> 
        <Border
            Padding="8"
            CornerRadius="10"
            Background="{DynamicResource Color3}"
            >
        <TabControl x:Name="Tabs" Style="{DynamicResource TabsStyle}" >

                <TabItem Header="Umetnicka dela" FontSize="15" Cursor="Hand" BorderThickness="0" BorderBrush="{DynamicResource Color3}" >
                <!-- LOGIKA PRVOG TABA-->

                    <Grid Background="{StaticResource Color3}">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"></RowDefinition>
                                <RowDefinition Height="3*"></RowDefinition>
                                <RowDefinition Height="*"></RowDefinition>
                            </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="250"/>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Pretraga po nazivu"
                                       FontSize="18"
                                       FontFamily="Georgia"
                                       Foreground="Black"
                                       VerticalAlignment="Center"
                                       Grid.Column="0"
                                       Margin="0,0,15,0"/>  

                            <TextBox x:Name="Pretraga_Naziv"
                                     TextChanged="Pretraga_Naziv_TextChanged"
                                     Grid.Column="1"
                                     VerticalAlignment="Center"
                                     Padding="4"
                                     Margin="0,0,15,0"/>

                            <ComboBox x:Name="FilterCombo"
                                      SelectionChanged="FilterCombo_SelectionChanged"
                                      Grid.Column="2"
                                      VerticalAlignment="Center"
                                      SelectedIndex="0"
                                      Margin="0,0,15,0">
                                <ComboBoxItem Content="Filtriranje po tipu" Foreground="Gray"/>
                                <ComboBoxItem Content="Fotografija"/>
                                <ComboBoxItem Content="Instalacija"/>
                                <ComboBoxItem Content="Mozaik"/>
                                <ComboBoxItem Content="NFT"/>
                                <ComboBoxItem Content="Skulptura"/>
                                <ComboBoxItem Content="Slika"/>
                            </ComboBox>

                            <Button x:Name="ResetFilters"
                                    Content="Reset"
                                    Grid.Column="3"
                                    VerticalAlignment="Center"
                                    Width="80"
                                    Margin="0,0,15,0"
                                    Click="ResetFilters_Click"/>
                        </Grid>

                        <DataGrid x:Name="Datagrid"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserResizeColumns="False"
                          ColumnWidth="1*" 
                          HorizontalScrollBarVisibility="Auto"
                          IsReadOnly="True"
                          SelectionMode="Extended"   
                          SelectionUnit="FullRow"
                                  >

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Šifra" Binding="{Binding Sifra}" Width="80">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="Naziv" Binding="{Binding Naziv}" Width="220">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="Autor" Binding="{Binding Autor}" Width="180">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="Godina nastanka" Binding="{Binding Godina}" Width="134">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="Tip" Binding="{Binding Tip}" Width="140">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                
                                <DataGridTemplateColumn Header="Ikonica" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Width="90" Height="64" CornerRadius="6"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Image Source="{Binding IkonicaPath}"
                                                               Stretch="Fill"
                                                               Margin="2"
                                                               SnapsToDevicePixels="True"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                    <!--BUTTONI-->
                    <Button x:Name="Dodaj" Command="{Binding AddCommand}" Click="Dodaj_Click" Grid.Row="2" Content="Dodaj" FontSize="20" FontFamily="Comic Sans MS" HorizontalAlignment="Left" Margin="10 5 0 5" Padding="30"></Button>

                    <Button x:Name="Izmeni" Click="Izmeni_Click" Grid.Row="2" Content="Izmeni" FontSize="20" FontFamily="Comic Sans MS" HorizontalAlignment="Left" Margin="140 5 0 5" Padding="30"></Button>

                    <Button x:Name="Izbirisi" Click="Izbirisi_Click"  Grid.Row="2" Content="Obrisi" FontSize="20" FontFamily="Comic Sans MS" HorizontalAlignment="Left" Margin="280 5 0 5" Padding="30"></Button>
                    <!--BUTTONI-->
                    </Grid>
                
            </TabItem>

            <TabItem Header="Postavke i kustosi" FontSize="15" Cursor="Hand">
                <!-- LOGIKA DRUGOG TABA-->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!--Odavde ide treeview za umetnicka dela-->
                        <GroupBox Header="Umetnicka dela" Grid.Column="0" Margin="10">
                            <DockPanel>
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" HorizontalAlignment="Center">
                                    <!--<Button Content="Dodaj" Width="100" Margin="5" Click="DodajTab21_Click" />-->
                                    <Button Content="Izmeni" Width="100" Margin="5" Click="IzmeniDela_Click"/>
                                    <Button Content="Izbrisi" Width="100" Margin="5" Click="IzbrisiDela_Click"/>
                                </StackPanel>
                                <TreeView x:Name="tvUmetnickaDela"  ItemsSource="{Binding Tipovi}" PreviewMouseRightButtonDown="tvUmetnickaDela_PreviewMouseRightButtonDown">
                                    <TreeView.ItemTemplate>
                                        <HierarchicalDataTemplate ItemsSource="{Binding Dela}">
                                            <TextBlock Text="{Binding Naziv}"/>
                                            <HierarchicalDataTemplate.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Image Source="{Binding IkonicaPath}" Width="40" Height="40" Margin="0 0 5 0"/>
                                                        <TextBlock Text="{Binding Naziv}" VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="Black"/>
                                                                    <Setter Property="FontStyle" Value="Normal"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Dodeljeno}" Value="True">
                                                                            <Setter Property="Foreground" Value="Gray"/>
                                                                            <Setter Property="FontStyle" Value="Italic"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </HierarchicalDataTemplate.ItemTemplate>
                                        </HierarchicalDataTemplate>
                                    </TreeView.ItemTemplate>
                                </TreeView>
                            </DockPanel>
                        </GroupBox>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="⇆" FontSize="24" />
                        </StackPanel>

                        <!--Odavde ide treeview za kustose-->
                        <GroupBox Header="Kustosi" Grid.Column="2" Margin="10">
                            <DockPanel>
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" HorizontalAlignment="Center">
                                    <Button Content="Dodaj" Width="100" Margin="5" Click="DodajTab22_Click"  FontFamily="Comic Sans MS"/>
                                    <Button Content="Izmeni" Width="100" Margin="5" Click="IzmeniKustose_Click"/>
                                    <Button Content="Izbrisi" Width="100" Margin="5" Click="IzbrisiKustose_Click"/>
                                </StackPanel>
                                <TreeView x:Name="KustosiTree" ItemsSource="{Binding Kustosi}" AllowDrop="True" Drop="KustosiTree_Drop" DragOver="KustosiTree_DragOver">
                                    <TreeView.ItemContainerStyle>
                                        <Style TargetType="TreeViewItem">
                                            <Setter Property="AllowDrop" Value="True"/>
                                        </Style>
                                    </TreeView.ItemContainerStyle>
                                    <TreeView.ItemTemplate>
                                        <HierarchicalDataTemplate ItemsSource="{Binding Dela}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding KustosIme}" Margin="0 0 5 0"/>
                                                <TextBlock Text="{Binding KustosPrezime}" Margin="0 0 5 0"/>
                                                <TextBlock Text="(JMBG:"/>
                                                <TextBlock Text="{Binding KustosJMBG}"/>
                                                <TextBlock Text=")"/>
                                            </StackPanel>
                                            <HierarchicalDataTemplate.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Image Source="{Binding IkonicaPath}" Width="40" Height="40" Margin="0 0 5 0"/>
                                                        <TextBlock Text="{Binding Naziv}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </HierarchicalDataTemplate.ItemTemplate>
                                        </HierarchicalDataTemplate>
                                    </TreeView.ItemTemplate>
                                </TreeView>

                            </DockPanel>
                        </GroupBox>
                    </Grid>


                </TabItem>
               

            </TabControl>
      </Border>
    </Grid>
</Window>
